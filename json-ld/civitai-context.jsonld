{
  "@context": {
    "@version": 1.1,
    "civitai": "https://developer.civitai.com/vocab#",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "air": "urn:air:",

    "Model": "civitai:Model",
    "ModelVersion": "civitai:ModelVersion",
    "ModelFile": "civitai:ModelFile",
    "Image": "civitai:Image",
    "Creator": "civitai:Creator",
    "Tag": "civitai:Tag",
    "User": "schema:Person",
    "Workflow": "civitai:Workflow",
    "WorkflowStep": "civitai:WorkflowStep",
    "Job": "civitai:Job",
    "Blob": "civitai:Blob",
    "VaultItem": "civitai:VaultItem",

    "id": "@id",
    "type": "@type",

    "name": "schema:name",
    "description": "schema:description",
    "url": "schema:url",
    "createdAt": { "@id": "schema:dateCreated", "@type": "xsd:dateTime" },
    "updatedAt": { "@id": "schema:dateModified", "@type": "xsd:dateTime" },
    "publishedAt": { "@id": "schema:datePublished", "@type": "xsd:dateTime" },
    "completedAt": { "@id": "civitai:completedAt", "@type": "xsd:dateTime" },
    "startedAt": { "@id": "civitai:startedAt", "@type": "xsd:dateTime" },

    "creator": { "@id": "schema:creator", "@type": "@id" },
    "tags": "schema:keywords",
    "thumbnailUrl": { "@id": "schema:thumbnailUrl", "@type": "@id" },
    "contentSize": "schema:contentSize",
    "encodingFormat": "schema:encodingFormat",
    "license": { "@id": "schema:license", "@type": "@id" },

    "modelType": "civitai:modelType",
    "baseModel": "civitai:baseModel",
    "baseModelType": "civitai:baseModelType",
    "air": { "@id": "civitai:air", "@type": "@id" },
    "downloadUrl": { "@id": "civitai:downloadUrl", "@type": "@id" },
    "files": { "@id": "civitai:files", "@container": "@set" },
    "modelVersions": { "@id": "civitai:modelVersions", "@container": "@set" },
    "trainedWords": { "@id": "civitai:trainedWords", "@container": "@set" },
    "hashes": "civitai:hashes",

    "nsfw": "civitai:nsfw",
    "nsfwLevel": "civitai:nsfwLevel",
    "allowCommercialUse": { "@id": "civitai:allowCommercialUse", "@container": "@set" },
    "allowDerivatives": "civitai:allowDerivatives",

    "prompt": "civitai:prompt",
    "negativePrompt": "civitai:negativePrompt",
    "seed": "civitai:seed",
    "steps": "civitai:steps",
    "cfgScale": "civitai:cfgScale",
    "sampler": "civitai:sampler",
    "width": "schema:width",
    "height": "schema:height",
    "duration": "schema:duration",
    "quantity": "civitai:quantity",

    "engine": "civitai:engine",
    "model": "civitai:model",
    "additionalNetworks": { "@id": "civitai:additionalNetworks", "@container": "@set" },

    "status": "civitai:status",
    "callbackUrl": { "@id": "civitai:callbackUrl", "@type": "@id" },
    "callbackEvents": { "@id": "civitai:callbackEvents", "@container": "@set" },
    "steps_list": { "@id": "civitai:steps", "@container": "@set" },
    "jobs": { "@id": "civitai:jobs", "@container": "@set" },
    "result": "civitai:result",
    "blobs": { "@id": "civitai:blobs", "@container": "@set" },

    "cost": "civitai:cost",
    "buzz": "civitai:buzz",
    "currency": "schema:priceCurrency",

    "permissions": "civitai:permissions",
    "canView": "civitai:canView",
    "canEdit": "civitai:canEdit",
    "canDelete": "civitai:canDelete",
    "canDownload": "civitai:canDownload",

    "vault": "civitai:vault",
    "tier": "civitai:membershipTier",
    "storageUsedKb": "civitai:storageUsedKb",
    "storageLimitKb": "civitai:storageLimitKb"
  }
}
